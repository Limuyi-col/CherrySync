{
  "name": "cherrysync",
  "version": "1.1.0",
  "description": "Lightweight multi-environment code sync CLI with environment-aware state tracking, backup, rollback, drift detection, and health checks.",
  "type": "module",
  "bin": {
    "cherrysync": "bin/cherrysync.js",
    "csync": "bin/csync.js"
  },
  "scripts": {
    "start": "node ./bin/csync.js",
    "lint": "node ./scripts/check.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Limuyi-col/CherrySync.git"
  },
  "homepage": "https://github.com/Limuyi-col/CherrySync#readme",
  "bugs": {
    "url": "https://github.com/Limuyi-col/CherrySync/issues"
  },
  "author": "Limuyi-col",
  "license": "MIT",
  "keywords": [
    "sftp",
    "sync",
    "deploy",
    "deployment",
    "cli",
    "multi-environment",
    "devops",
    "ssh",
    "backup",
    "rollback",
    "drift-detection",
    "health-check",
    "watch-mode"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "diff": "^7.0.0",
    "fast-glob": "^3.3.2",
    "prompts": "^2.4.2",
    "ssh2-sftp-client": "^11.0.0"
  }
}
